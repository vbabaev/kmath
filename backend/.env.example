PORT=3000
NODE_ENV=development
MONGO_URL=mongodb://localhost:27017/kmath

# Where the app is reachable from a browser. Used to build the OAuth
# callback URL and the post-login redirect target.
APP_URL=http://localhost:5173

# Long random string. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# OAuth client credentials from Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# First-time login: if the database is empty and someone logs in with this
# gmail address, a teacher profile is auto-created for them. After that
# every login must match the googleEmail on an existing profile.
BOOTSTRAP_TEACHER_EMAIL=

# Set to "true" in local dev to enable POST /api/auth/dev-login
# (lets you log in as any profile id without OAuth). Off in prod.
ALLOW_DEV_LOGIN=false
